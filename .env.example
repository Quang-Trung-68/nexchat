# Copy to `.env` cùng cấp `docker-compose.prod.yml` — biến dùng cho compose (interpolation) + build args.
# `apps/server/.env` chứa secret ứng dụng (JWT, OAuth, …).

GHCR_PREFIX=ghcr.io/yourgithubuser

POSTGRES_USER=chatapp
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=chat_app

# Build-time (Vite) — trùng với GitHub Actions secrets khi CI build client
VITE_API_URL=https://api.chat.nextech.io.vn
VITE_SOCKET_URL=https://api.chat.nextech.io.vn
