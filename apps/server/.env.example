NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chat_app_db
# Bản dev: nếu không chạy Redis, server vẫn khởi động (typing/presence trong RAM; không dùng redis-adapter).
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Email (Nodemailer) — dùng App Password nếu Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Chat App <noreply@chatapp.com>"

# Frontend URL (OAuth redirect + email links + deep link push)
CLIENT_URL=http://localhost:5173

# Web Push (VAPID) — `npx web-push generate-vapid-keys` trong apps/server
# Thiếu → không enqueue job push; worker không gửi.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Metered TURN (WebRTC) — https://www.metered.ca/ Thiếu → GET /api/webrtc/turn-credentials trả 500.
METERED_APP_NAME=
METERED_API_KEY=

# Cloudinary — upload ảnh chat (Bước 11). Thiếu → POST /api/messages/:id/images trả 503.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Upload ảnh (mặc định fallback từ @chat-app/shared-constants UPLOAD_DEFAULTS nếu không set)
# UPLOAD_MAX_IMAGES_PER_MESSAGE=10
# UPLOAD_MAX_IMAGE_BYTES_PER_FILE=5242880
# UPLOAD_MAX_IMAGE_DIMENSION_PX=1920

# -----------------------------------------------------------------------------
# Production (VPS — nexchat.io.vn)
# Copy file này thành apps/server/.env trên VPS, bỏ dấu # và điền giá trị thật.
# -----------------------------------------------------------------------------
# NODE_ENV=production
# PORT=5000
# DATABASE_URL=postgresql://chatapp:<POSTGRES_PASSWORD>@postgres:5432/chat_app?schema=public
# REDIS_URL=redis://redis:6379
# CLIENT_URL=https://nexchat.io.vn
# COOKIE_DOMAIN=.nexchat.io.vn
# TRUST_PROXY=1

# JWT (production — generate ngẫu nhiên, ví dụ: openssl rand -hex 64)
# JWT_ACCESS_SECRET=<random-64-hex>
# JWT_REFRESH_SECRET=<random-64-hex>
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (thêm callback URL vào Google Cloud Console)
# GOOGLE_CLIENT_ID=<your-google-client-id>
# GOOGLE_CLIENT_SECRET=<your-google-client-secret>
# GOOGLE_CALLBACK_URL=https://api.nexchat.io.vn/api/auth/google/callback

# Email (Nodemailer — Gmail App Password)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=<your-gmail>
# EMAIL_PASS=<your-app-password>
# EMAIL_FROM="NexChat <noreply@nexchat.io.vn>"

# Web Push VAPID (generate: cd apps/server && npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=<generated>
# VAPID_PRIVATE_KEY=<generated>
# VAPID_SUBJECT=mailto:<your-email>

# Metered TURN — https://www.metered.ca/
# METERED_APP_NAME=<your-app-name>
# METERED_API_KEY=<your-api-key>

# Cloudinary
# CLOUDINARY_CLOUD_NAME=<your-cloud-name>
# CLOUDINARY_API_KEY=<your-api-key>
# CLOUDINARY_API_SECRET=<your-api-secret>
