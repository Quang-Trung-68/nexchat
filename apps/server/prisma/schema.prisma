generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ConversationType {
  DM
  GROUP

  @@map("conversation_type")
}

enum ParticipantRole {
  OWNER
  MEMBER

  @@map("participant_role")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  CALL

  @@map("message_type")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED

  @@map("friendship_status")
}

enum NotificationType {
  NEW_MESSAGE
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  NEW_FRIEND_POST
  SYSTEM

  @@map("notification_type")
}

enum OAuthProvider {
  GOOGLE
  GITHUB

  @@map("oauth_provider")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  username    String    @unique
  // Optional phone — exact match only (add friend search).
  phone       String?   @unique @map("phone")
  displayName String    @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  bio         String?
  password    String? // nullable because of OAuth users
  emailVerifiedAt DateTime? @map("email_verified_at")
  isOnline    Boolean   @default(false) @map("is_online")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at") // soft delete

  oauthAccounts       OAuthAccount[]
  refreshTokens       RefreshToken[]
  emailVerificationToken EmailVerificationToken?
  forgotPasswordOtp      ForgotPasswordOtp?
  participations      ConversationParticipant[]
  sentMessages        Message[]                 @relation("SentMessages")
  messageReads        MessageRead[]
  reactions           Reaction[]
  sentFriendships     Friendship[]              @relation("FriendshipRequester")
  recvFriendships     Friendship[]              @relation("FriendshipAddressee")
  notifications       Notification[]
  pinsCreated         PinnedMessage[] @relation("PinnedByUser")
  pushSubscriptions   PushSubscription[]
  posts               Post[]
  postLikes           PostLike[]
  postComments        PostComment[]

  @@index([email])
  @@index([username])
  @@index([phone])
  @@index([deletedAt])
  @@map("users")
}

model OAuthAccount {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  provider   OAuthProvider
  providerId String        @map("provider_id") // ID from Google/GitHub
  createdAt  DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

/// Một mã OTP xác thực email đang hiệu lực (xoá / ghi đè khi gửi lại).
model EmailVerificationToken {
  userId    String   @id @map("user_id")
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

/// Mã OTP quên mật khẩu (không đăng nhập); một bản ghi / user.
model ForgotPasswordOtp {
  userId    String   @id @map("user_id")
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("forgot_password_otps")
}

model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType
  name        String? // null for DM
  avatarUrl   String?          @map("avatar_url") // null for DM
  description String? // group description
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at") // soft delete

  participants ConversationParticipant[]
  messages     Message[]
  pinnedMessages PinnedMessage[]

  @@index([type])
  @@index([deletedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String          @id @default(cuid())
  conversationId String          @map("conversation_id")
  userId         String          @map("user_id")
  role           ParticipantRole @default(MEMBER)
  lastReadAt     DateTime        @default(now()) @map("last_read_at") // per-room: used to compute unread count
  joinedAt       DateTime        @default(now()) @map("joined_at")
  deletedAt      DateTime?       @map("deleted_at") // soft delete (leaving a group)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@index([conversationId, deletedAt])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  type           MessageType @default(TEXT)
  callId         String?     @unique @map("call_id")
  content        String? // null for file-only messages
  fileUrl        String?     @map("file_url") // Cloudinary URL
  fileName       String?     @map("file_name") // original filename
  fileSize       Int?        @map("file_size") // bytes
  parentId       String?     @map("parent_id") // reply/thread: points to parent message
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at") // soft delete

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  parent       Message?     @relation("MessageReplies", fields: [parentId], references: [id])
  replies      Message[]    @relation("MessageReplies")
  reads         MessageRead[]
  reactions     Reaction[]
  attachments   MessageAttachment[]
  pinnedMessage PinnedMessage?

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([parentId])
  @@index([conversationId, deletedAt])
  @@map("messages")
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

// Tin ghim trong hội thoại (giới hạn số lượng ở tầng ứng dụng).
model PinnedMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  messageId      String   @unique @map("message_id")
  pinnedBy       String   @map("pinned_by")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user         User         @relation("PinnedByUser", fields: [pinnedBy], references: [id], onDelete: Cascade)

  @@index([conversationId, pinnedAt(sort: Desc)])
  @@map("pinned_messages")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("message_reads")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String // e.g. "👍", "❤️", "😂"
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@map("reactions")
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String           @map("requester_id") // person who sent the request
  addresseeId String           @map("addressee_id") // person who received the request
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId]) // cannot send the same request twice
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id") // recipient of the notification
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  data      Json? // flexible payload: { conversationId, senderId, ... }
  createdAt DateTime         @default(now()) @map("created_at")
  deletedAt DateTime?        @map("deleted_at") // soft delete

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead]) // very fast query for "unread notifications of user X"
  @@index([userId, createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

// Web Push (VAPID): một bản ghi / endpoint / thiết bị.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String   @map("p256dh")
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Post {
  id        String   @id @default(cuid())
  authorId  String   @map("author_id")
  content   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images   PostImage[]
  likes    PostLike[]
  comments PostComment[]

  @@index([authorId, createdAt(sort: Desc)])
  @@map("posts")
}

model PostImage {
  id        String @id @default(cuid())
  postId    String @map("post_id")
  url       String
  sortOrder Int    @default(0) @map("sort_order")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_images")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String    @id @default(cuid())
  postId    String    @map("post_id")
  authorId  String    @map("author_id")
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([authorId])
  @@map("post_comments")
}
