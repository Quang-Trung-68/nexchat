# =============================================================================
# GitHub Container Registry (CI/CD) — BẮT BUỘC cho docker-compose.prod.yml
# Phải trùng owner GitHub (chữ thường) mà workflow push image: ghcr.io/<owner>/chat-app-*:latest
# Ví dụ repo github.com/MyUser/chat-app → GHCR_PREFIX=ghcr.io/myuser
# =============================================================================
GHCR_PREFIX=ghcr.io/thay-bang-github-owner-chu-thuong

# =============================================================================
# chat-app — Environment Variables for Production Deployment
#
# Instructions:
# 1. Copy file này thành .env ở thư mục root repo trên VPS (cùng cấp docker-compose.prod.yml)
# 2. Điền ĐẦY ĐỦ mọi giá trị <your-...>
# 3. KHÔNG commit .env lên git (đã có trong .gitignore)
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=<your-strong-db-password>
POSTGRES_DB=chat_app

# --- Vite Frontend Build Args (baked into JS bundle at build time) ---
# Trùng với GitHub Actions Secrets VITE_API_URL + VITE_SOCKET_URL
VITE_API_URL=https://api.nexchat.io.vn
VITE_SOCKET_URL=https://api.nexchat.io.vn
